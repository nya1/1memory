{
  "name": "justmemory",
  "version": "0.0.1",
  "license": "Apache-2.0",
  "type": "module",
  "packageManager": "pnpm@9.15.9",
  "bin": {
    "justmemory": "./dist/cli.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nya1/justmemory.git"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepublishOnly": "tsc -p tsconfig.json && node scripts/download-embedding-model.mjs",
    "setup:embeddings": "node scripts/download-embedding-model.mjs",
    "predev:mcp": "node scripts/download-embedding-model.mjs",
    "pretest": "node scripts/download-embedding-model.mjs",
    "dev:mcp": "tsx src/cli.ts mcp",
    "dev:explore": "tsx src/cli.ts explore",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist",
    "models"
  ],
  "dependencies": {
    "@huggingface/transformers": "^3.5.2",
    "@lancedb/lancedb": "^0.21.0",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "ink": "5",
    "ink-text-input": "6",
    "nanoid": "^5.1.5",
    "react": "18",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@types/react": "18",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3",
    "vitest": "^3.1.1"
  }
}
